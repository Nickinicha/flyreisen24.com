// ── LANGUAGE SWITCHING ────────────────────────────────────────
function setLang(lang) {
  const t = T[lang];
  // HTML lang attr
  document.documentElement.lang = t.htmlLang;
  // Meta
  document.title = t.pageTitle;
  document.querySelector('meta[name="description"]').content = t.pageDesc;
  document.querySelector('meta[property="og:title"]').content = t.pageTitle;
  // Nav
  document.getElementById('breadHome').textContent = t.breadHome;
  document.getElementById('breadDeals').textContent = t.breadDeals;
  document.getElementById('navFlight').textContent = t.navFlight;
  document.getElementById('navHotel').textContent = t.navHotel;
  document.getElementById('navDeals').textContent = t.navDeals;
  document.getElementById('navKnowledge').textContent = t.navKnowledge;
  document.getElementById('navKnowledgeLink').href = t.navKnowledgeHref;
  document.getElementById('navTools').textContent = t.navTools;
  document.getElementById('currentLang').textContent = t.currentLang;
  // Hero
  document.getElementById('heroBadge').textContent = t.heroBadge;
  document.getElementById('heroTitle').textContent = t.heroTitle;
  document.getElementById('heroSub').textContent = t.heroSub;
  document.getElementById('heroPills').innerHTML = t.heroPills;
  document.getElementById('sectionHeading').textContent = t.sectionHeading;
  // Contact popup
  document.getElementById('contactTitle').textContent = t.contactTitle;
  document.getElementById('labelName').textContent = t.labelName;
  document.getElementById('labelEmail').textContent = t.labelEmail;
  document.getElementById('labelMsg').textContent = t.labelMsg;
  document.getElementById('submitBtn').textContent = t.submitBtn;
  document.getElementById('successMessage').textContent = t.successMsg;
  document.getElementById('errorMessage').textContent = t.errorMsg;
  // Footer
  document.getElementById('footerNav').textContent = t.footerNav;
  document.getElementById('footerFlight').textContent = t.footerFlight;
  document.getElementById('footerHotel').textContent = t.footerHotel;
  document.getElementById('footerDeals').textContent = t.footerDeals;
  document.getElementById('footerKnowledge').textContent = t.footerKnowledge;
  document.getElementById('footerKnowledge').href = t.navKnowledgeHref;
  document.getElementById('footerTools').textContent = t.footerTools;
  document.getElementById('footerLangH').textContent = t.footerLangH;
  document.getElementById('footerLegal').textContent = t.footerLegal;
  document.getElementById('footerAbout').textContent = t.footerAbout;
  document.getElementById('footerAbout').href = t.footerAboutHref;
  document.getElementById('footerTerms').textContent = t.footerTerms;
  document.getElementById('footerTerms').href = t.footerTermsHref;
  document.getElementById('footerPrivacy').textContent = t.footerPrivacy;
  document.getElementById('footerPrivacy').href = t.footerPrivacyHref;
  document.getElementById('footerCopy').textContent = t.footerCopy;
  // Show/hide content blocks
  document.getElementById('content-th').style.display = lang === 'th' ? '' : 'none';
  document.getElementById('content-en').style.display = lang === 'en' ? '' : 'none';
  document.getElementById('content-de').style.display = lang === 'de' ? '' : 'none';
  // Lang dropdown active state
  ['th','en','de'].forEach(l => {
    const el = document.getElementById('langOpt' + l.toUpperCase());
    if (el) el.classList.toggle('active', l === lang);
  });
  // Save preference
  localStorage.setItem('flyLang', lang);
  // Close dropdown
  document.getElementById('languageDropdown').classList.remove('active');
}

// ── UI HELPERS ────────────────────────────────────────────────
function toggleLangDropdown() {
  document.getElementById('languageDropdown').classList.toggle('active');
}
function toggleMenu() {
  document.getElementById('topNavMenu').classList.toggle('active');
}
function toggleContact() {
  document.getElementById('contactPopup').classList.toggle('active');
}
document.addEventListener('click', e => {
  const d = document.getElementById('languageDropdown');
  if (d && !d.contains(e.target)) d.classList.remove('active');
});

// ── CONTACT FORM ──────────────────────────────────────────────
document.getElementById('contactForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = this.querySelector('.submit-btn');
  const ok  = document.getElementById('successMessage');
  const err = document.getElementById('errorMessage');
  btn.disabled = true;
  try {
    const r = await fetch(this.action, {method:'POST', body: new FormData(this), headers:{'Accept':'application/json'}});
    if (r.ok) { ok.classList.add('show'); err.classList.remove('show'); this.reset(); setTimeout(()=>{ toggleContact(); ok.classList.remove('show'); }, 3000); }
    else throw new Error();
  } catch { err.classList.add('show'); ok.classList.remove('show'); }
  finally { btn.disabled = false; btn.textContent = T[localStorage.getItem('flyLang')||'th'].submitBtn; }
});

// ── INIT ──────────────────────────────────────────────────────
(function() {
  const saved = localStorage.getItem('flyLang') || 'th';
  setLang(saved);
})();
</script>
